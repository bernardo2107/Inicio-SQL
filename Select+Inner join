SELECT p.ProductName AS 'Nome do Produto', 
s.suppliername AS 'Nome do fornecedor', 
s.country AS 'País do Fornecedor', 
s.SupplierID AS 'ID do Fornecedor'
FROM suppliers AS s INNER JOIN products AS p
ON s.SupplierID = p.SupplierID
WHERE CategoryID = 2;

-- EX11:
SELECT p.productName AS 'Nome do Produto',
s.supplierName AS 'Nome do Fornecedor'
FROM products AS p
RIGHT JOIN suppliers AS s 
ON s.supplierid = p.supplierid;

-- EX12:
SELECT p.productName AS 'Nome do Produto',
s.country AS 'Pais',
s.supplierID AS 'Nome do Fornecedor'
FROM products AS p
RIGHT JOIN suppliers AS s 
ON s.supplierid = p.supplierid
WHERE Country = 'Germany';

-- EX13:
SELECT s.shipperID AS 'Nome da transportadora',
o.orderID AS 'ID do pedido'
FROM orders AS o
RIGHT JOIN shippers AS s
ON s.shipperID = o.shipperID;

 -- EX14:
 SELECT p.productname AS 'Nome do Produto',
 su.suppliername AS 'Nome do Fornecedor',
 s.shippername AS 'Nome da transportadora',
 o.orderid AS 'Id do pedido'
 FROM Products AS p
 INNER JOIN suppliers AS su 
 ON su.supplierid = p.supplierid
 INNER JOIN orderdetails as od
 ON p.productid = od.productid
 INNER JOIN orders AS o 
 ON od.orderid = o.orderid
 INNER JOIN shippers AS s 
 ON o.shipperid = s.shipperid
 WHERE o.orderid = 10250;
