CREATE TABLE RelatorioFinal AS
SELECT CONCAT(
       e.FirstName,
       ' ',
       e.LastName
       ) AS 'Funcionario',
       COUNT(o.OrderID) AS 'Total de Encomendas'
FROM Employees e
JOIN Orders o
ON e.EmployeeID = o.EmployeeID
GROUP BY e.EmployeeID,
         e.FirstName,
         e.LastName
HAVING COUNT(o.OrderID) > 5
ORDER BY COUNT(o.OrderID) DESC
LIMIT 3;
