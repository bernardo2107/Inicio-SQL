Ex30:
SELECT c.Country AS PAIS,
       COUNT(DISTINCT s.ShipperID) AS 'Quantidade Transportadoras'
FROM Customers c
JOIN Orders o
    ON c.CustomerID = o.CustomerID
JOIN Shippers s
    ON o.ShipperID = s.ShipperID
GROUP BY c.Country
HAVING COUNT(DISTINCT s.ShipperID) > 1;

