 -- EX14:
 SELECT p.productname AS 'Nome do Produto',
 su.suppliername AS 'Nome do Fornecedor',
 s.shippername AS 'Nome da transportadora',
 o.orderid AS 'Id do pedido'
 FROM Products AS p
 INNER JOIN suppliers AS su ON su.supplierid = p.supplierid
 INNER JOIN orderdetails as od ON p.productid = od.productid
 INNER JOIN orders AS o ON od.orderid = o.orderid
 INNER JOIN shippers AS s ON o.shipperid = s.shipperid
 WHERE o.orderid = 10248;
 
 -- EX15:
 SELECT su.suppliername AS 'Nome do Fornecedor',
 su.city AS 'Cidade',
 o.orderdate AS 'Data do Pedido',
 s.shippername AS 'Nome da transportadora',
 p.productname AS 'Nome do Produto'
 FROM suppliers AS su
 INNER JOIN products AS p ON p.supplierid = su.supplierid
 INNER JOIN orderdetails AS od ON p.productid = od.productid
 INNER JOIN orders AS o ON od.orderid = o.orderid
  INNER JOIN shippers AS s
WHERE s.shippername = 'United Package';

 -- EX16:
  SELECT s.suppliername AS 'Nome do Fornecedor',
  P.productname AS 'Nome do Produto',
  od.orderid AS 'ID do Pedido'
FROM suppliers AS s
JOIN products p ON p.supplierid = s.supplierid
LEFT JOIN Orderdetails od ON od.productid = p.productid
WHERE od.orderid IS NULL;

-- EX17:
  SELECT s.contactname AS 'Nome de contato',
  p.productname AS 'Nome do Produto',
  c.categoryid AS 'ID da categoria',
  s.country AS 'Pais'
FROM suppliers s
JOIN products p ON p.supplierid = s.supplierid
JOIN categories AS c ON c.categoryID = p.categoryid
WHERE c.categoryid IN (1,3,5) AND s.Country = 'UK';

-- EX18:
 SELECT su.supplierid AS 'ID do fornecedor',
 su.suppliername AS 'Nome do Fornecedor',
 COUNT(od.orderid) AS 'Total de Pedidos'
FROM products AS p 
JOIN suppliers su ON su.supplierid = p.supplierid
JOIN orderdetails od ON p.productid = od.productid
GROUP BY su.supplierid, su.suppliername;

-- EX19:
  SELECT su.suppliername AS 'Nome do Fornecedor',
  c.categoryname AS 'Nome da Categoria',
  p.productname AS 'Nome do Produto'
FROM Products p
JOIN suppliers su ON su.supplierid = p.supplierid
JOIN categories c ON c.categoryid = p.categoryid
WHERE p.price > (SELECT AVG(price)
  FROM products  );

-- EX20:
 SELECT su.suppliername AS 'Nome do Fornecedor',
 o.orderid AS 'ID do Pedido',
 p.productname AS 'Nome do Produto',
 s.shippername AS 'Nome da transportadora'
FROM Products p 
JOIN Suppliers su ON su.supplierid = p.supplierid
JOIN orderdetails od ON p.productid = od.productid
JOIN Orders o ON o.orderid = od.orderid
JOIN shippers s ON o.shipperid = s.shipperid;
