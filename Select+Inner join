-- EX10:
SELECT s.shipperName AS 'Nome da Transportadora',
s.ShipperID AS 'ID da Transpotadora',
COUNT(o.orderid) AS 'Quantidade de Pedidos'
FROM Shippers AS s
LEFT JOIN Orders AS o 
ON s.shipperid = o.shipperid
GROUP BY s.ShipperID,s.shippername;

